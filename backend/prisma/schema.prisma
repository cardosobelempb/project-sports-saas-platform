generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
}

enum VisibilityStatus {
  VISIBLE
  HIDDEN
  ARCHIVED
}

enum YesNoStatus {
  YES
  NO
}

enum MembershipRole {
  OWNER
  ADMIN
  AFFILIATE
  OPERATOR
  CUSTOMER
  MANAGER
  SUPPORT
  FINANCE
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  SUSPENDED
  REMOVED
  DELETED
}

enum DocumentType {
  CPF
  CNPJ
  RG
  OTHER
}

enum DeliveryMethod {
  DELIVERY
  PICKUP
  TABLE
  OTHER
}

enum DeliveryFeeType {
  FIXED
  BY_DISTANCE
  BY_CEP
  MANUAL
}

enum PaymentMethod {
  MONEY
  DEBIT_CARD
  CREDIT_CARD
  FOOD_CARD
  PIX
  ONLINE
  OTHER
}

enum PaymentGateway {
  MERCADO_PAGO
  PAGSEGURO
  GETNET
  PIX_MANUAL
  OTHER
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  REFUNDED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELED
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELED
  SUSPENDED
}

enum SubscriptionMode {
  TRIAL
  PAID
  VOUCHER
  MANUAL
}

enum VoucherStatus {
  UNUSED
  USED
  EXPIRED
  CANCELED
}

enum BannerScope {
  STORE
  MARKETPLACE
}

enum MediaType {
  PRODUCT
  CATEGORY
  STORE
  BANNER
  OTHER
}

enum DomainType {
  STORE
  MARKETPLACE
  CUSTOM
}

enum ScheduleAction {
  OPEN
  CLOSE
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  BLOCKED
  DELETED
}

enum UserProfileStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum ConsentStatus {
  ACTIVE
  REVOKED
  WITHDRAWN
  EXPIRED
  PENDING
}

enum TokenType {
  REFRESH
  ACCESS
  RESET_PASSWORD
  EMAIL_VERIFICATION
  API_KEY
}

enum ProviderType {
  GOOGLE
  FACEBOOK
  APPLE
  CREDENTIALS
  OTHER
}

enum TenantStatus {
  TRIALING
  ACTIVE
  SUSPENDED
  CANCELED
}

enum AddressType {
  HOME
  WORK
  OTHER
}

enum MatchType {
  FRIENDLY
  RANKED
  TOURNAMENT
  TRAINING
  CHALLENGE
  CASUAL
}

enum MatchPeriodType {
  DAILY
  WEEKLY
  MONTHLY
  ANNUAL
}

enum MatchStatus {
  PENDING
  IN_PROGRESS
  CONFIRMED
  DISPUTED
  FINISHED
  CANCELLED
  ADMIN_APPROVED
}

enum RankingScope {
  CITY
  STATE
  CLUB
  NATIONAL
  AGE_GROUP
  LEVEL
}

enum TournamentFrequency {
  DAILY
  WEEKLY
  MONTHLY
  ANNUAL
  CUSTOM
}

enum TournamentFormat {
  KNOCKOUT
  GROUP_STAGE
  ROUND_ROBIN
  DOUBLE_ELIMINATION
}

enum MatchValidation {
  PENDING
  CONFIRMED_BY_BOTH
  ADMIN_APPROVED
  DISPUTED
}

enum SportType {
  INDIVIDUAL
  TEAM
  DUO
}

enum ScoringType {
  POINTS
  GOALS
  SETS
  TIME
  DISTANCE
}

enum WinCondition {
  HIGHEST_SCORE
  BEST_OF
  LOWEST_SCORE
  TIME_BASED
}

enum RankingHistoryReason {
  MATCH_WIN
  MATCH_LOSS
  MATCH_DRAW
  ADMIN_ADJUSTMENT
  PENALTY
}

// ============================================================
// MODULE: IDENTITY_ACCESS
// ============================================================
// -----------------------------------------------------------------------------
// Autenticação no padrão NextAuth
// -----------------------------------------------------------------------------

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  emailVerified DateTime? @map("email_verified")
  passwordHash  String    @map("password_hash") @db.VarChar(255)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  accounts     Account[]
  sessions     Session[]
  tokens       Token[]
  profile      UserProfile?
  otps         Otp[]
  memberships  Membership[]
  addresses    Address[]
  lgpdConsents LgpdConsent[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Account {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  providerType      ProviderType @default(CREDENTIALS) @map("provider_type")
  provider          String       @db.VarChar(50)
  providerAccountId String       @map("provider_account_id") @db.VarChar(255)

  refreshToken String? @map("refresh_token") @db.Text
  accessToken  String? @map("access_token") @db.Text
  expiredAt     Int?    @map("expired_at")
  scope        String? @db.Text
  idToken      String? @map("id_token") @db.Text
  sessionState String? @map("session_state") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([deletedAt])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  userId       String   @map("user_id") @db.Uuid
  expiredAt     DateTime @map("expired_at")

  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(500)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiredAt])
  @@index([deletedAt])
  @@map("sessions")
}

model VerificationToken {
  id         String    @id @default(uuid()) @db.Uuid
  identifier String    @db.VarChar(255)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(255)
  expiredAt   DateTime  @map("expired_at")
  usedAt     DateTime? @map("used_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([identifier])
  @@index([expiredAt])
  @@map("verification_tokens")
}

// Tokens internos da aplicação: refresh, reset password, API token etc.
model Token {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      TokenType @default(REFRESH)
  valueHash String    @map("value_hash") @db.VarChar(255)
  expiredAt  DateTime  @map("expired_at")
  revokedAt DateTime? @map("revoked_at")

  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.VarChar(500)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, type])
  @@index([expiredAt])
  @@index([revokedAt])
  @@index([deletedAt])
  @@map("tokens")
}

// -----------------------------------------------------------------------------
// SaaS / Multi-tenant
// -----------------------------------------------------------------------------

model Tenant {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(150)
  slug           String       @unique @db.VarChar(150)
  documentNumber String?      @unique @map("document_number") @db.VarChar(30)
  contactEmail   String?      @map("contact_email") @db.VarChar(255)
  phone          String?      @db.VarChar(20)
  status         TenantStatus @default(TRIALING)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  memberships   Membership[]
  organizations Organization[]

  @@index([status])
  @@index([deletedAt])
  @@map("tenants")
}

model Organization {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  name    String  @db.VarChar(150)
  slug    String  @db.VarChar(150)
  logoUrl String? @map("logo_url") @db.VarChar(500)

  status OrganizationStatus @default(ACTIVE)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
  @@index([deletedAt])
  @@map("organizations")
}

model Membership {
  id             String  @id @default(uuid()) @db.Uuid
  userId         String  @map("user_id") @db.Uuid
  tenantId       String  @map("tenant_id") @db.Uuid
  organizationId String? @map("organization_id") @db.Uuid

  role   MembershipRole   @default(MEMBER)
  status MembershipStatus @default(ACTIVE)

  joinedAt     DateTime? @map("joined_at")
  invitedEmail String?   @map("invited_email") @db.VarChar(255)
  invitedById  String?   @map("invited_by_id") @db.Uuid
  expiredAt     DateTime? @map("expired_at")
  removedAt    DateTime? @map("removed_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, organizationId])
  @@index([userId])
  @@index([tenantId])
  @@index([organizationId])
  @@index([tenantId, role])
  @@index([tenantId, status])
  @@index([deletedAt])
  @@map("memberships")
}

model Otp {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  phone     String    @db.VarChar(30)
  codeHash  String    @map("code_hash") @db.VarChar(255)
  ipAddress String?   @map("ip_address")
  expiredAt  DateTime  @map("expired_at")
  attempts  Int       @default(0)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone])
  @@index([userId])
  @@index([expiredAt])
  @@index([deletedAt])
  @@map("otps")
}

model UserProfile {
  id             String            @id @default(uuid()) @db.Uuid
  userId         String            @unique @map("user_id") @db.Uuid
  firstName      String?           @map("first_name") @db.VarChar(100)
  lastName       String?           @map("last_name") @db.VarChar(100)
  displayName    String?           @map("display_name") @db.VarChar(150)
  fullName       String?           @map("full_name") @db.VarChar(200)
  documentType   DocumentType     @map("document_type")
  documentNumber String?           @unique @map("document_number") @db.VarChar(30)
  phone          String?           @db.VarChar(20)
  birthDate      DateTime?         @map("birth_date") @db.Date
  avatarUrl      String?           @map("avatar_url") @db.VarChar(500)
  status         UserProfileStatus @default(ACTIVE)
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime?         @updatedAt @map("updated_at")
  deletedAt      DateTime?         @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentNumber])
  @@index([phone])
  @@index([deletedAt])
  @@map("user_profiles")
}

// -----------------------------------------------------------------------------
// LGPD e logs operacionais
// -----------------------------------------------------------------------------

model LgpdConsent {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  consentTerms       Boolean @map("consent_terms")
  consentMarketing   Boolean @map("consent_marketing")
  consentDataSharing Boolean @map("consent_data_sharing")
  consentAnalytics   Boolean @map("consent_analytics")

  ipAddress      String        @map("ip_address") @db.VarChar(45)
  macAddress     String?       @map("mac_address") @db.VarChar(20)
  userAgent      String        @map("user_agent") @db.VarChar(500)
  consentVersion String        @map("consent_version") @db.VarChar(10)
  status         ConsentStatus @default(ACTIVE)
  withdrawnAt    DateTime?     @map("withdrawn_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, consentVersion])
  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@map("lgpd_consents")
}

// ============================================================
// MODULE: GEO
// ============================================================
model State {
  id        String    @id @default(uuid()) @db.Uuid
  name      String?   @map("name") @db.VarChar(75)
  uf        String?   @db.VarChar(5)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  cities    City[]
  addresses Address[]

  @@unique([uf])
  @@index([deletedAt])
  @@map("states")
}

model City {
  id        String  @id @default(uuid()) @db.Uuid
  name      String? @map("name") @db.VarChar(120)
  stateId   String? @map("state_id") @db.Uuid
  subdomain String? @map("subdomain") @db.VarChar(255)

  state     State?    @relation(fields: [stateId], references: [id], onDelete: SetNull)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  addresses Address[]

  @@index([stateId])
  @@index([subdomain])
  @@index([deletedAt])
  @@map("cities")
}

model Athlete {
  id       String  @id @default(uuid()) @db.Uuid
  nickname String? @db.VarChar(100)

  // Dados esportivos
  dominantHand String? @map("dominant_hand") @db.VarChar(10)
  playingStyle String? @map("playing_style") @db.VarChar(50)

  // Status competitivo
  isProfessional Boolean @default(false)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  rankings AthleteRanking[]

  @@index([deletedAt])
  @@map("athletes")
}

model Address {
  id          String      @id @default(uuid()) @db.Uuid
  userId      String?     @map("user_id") @db.Uuid
  addressType AddressType @default(HOME) @map("address_type")

  street        String? @map("street") @db.VarChar(255)
  addressNumber String? @map("address_number") @db.VarChar(255)
  complement    String? @map("complement") @db.VarChar(255)
  neighborhood  String? @map("neighborhood") @db.VarChar(255)
  reference     String? @map("reference") @db.VarChar(255)

  cityId  String? @map("city_id") @db.Uuid
  stateId String? @map("state_id") @db.Uuid

  zipCode String? @map("zip_code") @db.VarChar(255)
  country String? @map("country") @db.VarChar(255)

  isPrimary Boolean @default(false)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  city  City?  @relation(fields: [cityId], references: [id], onDelete: SetNull)
  state State? @relation(fields: [stateId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([stateId])
  @@index([cityId])
  @@index([deletedAt])
  @@map("addresses")
}

model Sport {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  sportType   SportType @map("sport_type")
  isTeamSport Boolean   @default(false) @map("is_team_sport")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  ruleSets        RuleSet[]
  matches         Match[]
  tournaments     Tournament[]
  athleteRankings AthleteRanking[]

  @@index([deletedAt])
  @@map("sports")
}

model RuleSet {
  id      String @id @default(uuid()) @db.Uuid
  sportId String @map("sport_id") @db.Uuid
  name    String

  scoringType  ScoringType  @map("scoring_type")
  winCondition WinCondition @map("win_condition")

  maxPeriods    Int? @map("max_periods")
  pointsToWin   Int? @map("points_to_win")
  minDifference Int? @map("min_difference")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  sport   Sport   @relation(fields: [sportId], references: [id])
  matches Match[]

  @@index([deletedAt])
  @@map("rule_sets")
}

model Match {
  id        String    @id @default(uuid()) @db.Uuid
  sportId   String    @map("sport_id") @db.Uuid
  ruleSetId String    @map("rule_set_id") @db.Uuid
  matchType MatchType @map("match_type")

  status     MatchStatus
  startedAt  DateTime?   @map("started_at")
  finishedAt DateTime?   @map("finished_at")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime?   @updatedAt @map("updated_at")
  deletedAt  DateTime?   @map("deleted_at")

  sport   Sport   @relation(fields: [sportId], references: [id])
  ruleSet RuleSet @relation(fields: [ruleSetId], references: [id])

  participants MatchParticipant[]
  periods      MatchPeriodType[]
  scoreboard   Scoreboard?

  tournamentMatch TournamentMatch?

  matchPeriods MatchPeriod[]

  @@index([deletedAt])
  @@map("matches")
}

model MatchParticipant {
  id      String @id @default(uuid()) @db.Uuid
  matchId String @unique @map("match_id") @db.Uuid

  athleteId String? @map("athlete_id") @db.Uuid
  teamId    String? @map("team_id") @db.Uuid

  side       String
  totalScore Int     @default(0)
  isWinner   Boolean @default(false)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  match Match @relation(fields: [matchId], references: [id])

  @@index([deletedAt])
  @@map("match_participants")
}

model MatchPeriod {
  id           String    @id @default(uuid()) @db.Uuid
  matchId      String    @unique @map("match_id") @db.Uuid
  periodNumber Int       @map("period_number")
  name         String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  match  Match              @relation(fields: [matchId], references: [id])
  scores MatchPeriodScore[]

  @@index([deletedAt])
  @@map("match_periods")
}

model MatchPeriodScore {
  id            String    @id @default(uuid()) @db.Uuid
  periodId      String    @map("period_id") @db.Uuid
  participantId String    @map("participant_id") @db.Uuid
  score         Int
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  period MatchPeriod @relation(fields: [periodId], references: [id])

  @@index([deletedAt])
  @@map("match_period_scores")
}

model Scoreboard {
  id      String @id @default(uuid()) @db.Uuid
  matchId String @unique @map("match_id") @db.Uuid

  currentSet Int @default(1) @map("current_set")

  playerAId String @map("player_a_id")
  playerBId String @map("player_b_id")

  playerAPoints Int @default(0) @map("player_a_points")
  playerBPoints Int @default(0) @map("player_b_points")

  playerASets Int @default(0) @map("player_a_sets")
  playerBSets Int @default(0) @map("player_b_sets")

  firstServerId   String @map("first_server_id")
  currentServerId String @map("current_server_id")

  hasSwitchedSides Boolean @default(false) @map("has_switched_sides")

  isFinished Boolean   @default(false) @map("is_finished")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  match Match @relation(fields: [matchId], references: [id])

  @@index([deletedAt])
  @@map("scoreboards")
}

model PointEvent {
  id        String @id @default(uuid()) @db.Uuid
  matchId   String @unique @map("match_id") @db.Uuid
  setNumber Int    @map("set_number")

  playerId    String      @map("player_id") @db.Uuid
  serverId    String      @map("server_id") @db.Uuid
  scoringType ScoringType @map("scoring_type")

  pointNumber Int @map("point_number")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("point_events")
}

model Tournament {
  id   String @id @default(uuid()) @db.Uuid
  name String

  sportId   String   @map("sport_id") @db.Uuid
  startDate DateTime @map("start_date")

  format TournamentFormat

  sport Sport @relation(fields: [sportId], references: [id])

  categories TournamentCategory[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("tournaments")
}

model TournamentCategory {
  id           String @id @default(uuid()) @db.Uuid
  tournamentId String @map("tournament_id") @db.Uuid

  name      String
  minAge    Int?      @map("min_age")
  maxAge    Int?      @map("max_age")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tournament Tournament @relation(fields: [tournamentId], references: [id])

  participants TournamentParticipant[]
  matches      TournamentMatch[]

  @@index([deletedAt])
  @@map("tournament_categories")
}

model TournamentParticipant {
  id         String    @id @default(uuid()) @db.Uuid
  categoryId String    @map("category_id") @db.Uuid
  athleteId  String    @map("athlete_id") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  category TournamentCategory @relation(fields: [categoryId], references: [id])

  @@index([deletedAt])
  @@map("tournament_participants")
}

model TournamentMatch {
  id         String @id @default(uuid()) @db.Uuid
  categoryId String @map("category_id") @db.Uuid

  playerAId String  @map("player_a_id") @db.Uuid
  playerBId String? @map("player_b_id") @db.Uuid

  round    Int
  position Int

  matchId   String?   @unique @map("match_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  category TournamentCategory @relation(fields: [categoryId], references: [id])
  match    Match?             @relation(fields: [matchId], references: [id])

  @@index([deletedAt])
  @@map("tournament_matches")
}

model AthleteRanking {
  id String @id @default(uuid()) @db.Uuid

  athleteId String @map("athlete_id") @db.Uuid
  sportId   String @map("sport_id") @db.Uuid

  rating Int @default(1000)
  xp     Int @default(0)

  wins          Int @default(0)
  losses        Int @default(0)
  draws         Int @default(0)
  matchesPlayed Int @default(0) @map("matches_played")

  currentStreak Int @default(0) @map("current_streak")
  bestStreak    Int @default(0) @map("best_streak")

  cityId String? @map("city_id") @db.Uuid
  clubId String? @map("club_id") @db.Uuid

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  athlete Athlete @relation(fields: [athleteId], references: [id])
  sport   Sport   @relation(fields: [sportId], references: [id])

  history RankingHistory[]

  @@unique([athleteId, sportId])
  @@index([sportId, rating])
  @@index([sportId, cityId, rating])
  @@index([sportId, clubId, rating])
  @@map("athlete_rankings")
}

model RankingHistory {
  id String @id @default(uuid()) @db.Uuid

  athleteRankingId String  @map("athlete_ranking_id") @db.Uuid
  matchId          String? @unique @map("match_id") @db.Uuid

  oldRating    Int @map("old_rating")
  newRating    Int @map("new_rating")
  ratingChange Int @map("rating_change")

  oldXp    Int @map("old_xp")
  newXp    Int @map("new_xp")
  xpChange Int @map("xp_change")

  reason RankingHistoryReason

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  ranking AthleteRanking @relation(fields: [athleteRankingId], references: [id])

  @@index([athleteRankingId])
  @@index([matchId])
  @@index([createdAt])
  @@map("ranking_history")
}
